/* =============================================
   VARIABLES DE COLOR
   ============================================= */
:root {
    --bg: #fef9f2;
    --card-bg: #ffffff;
    --text-primary: #2c3e50;
    --text-secondary: #64748b;
    --accent: #f8d5aa;
    --accent-light: #fbe9d2;
    --accent-dark: #e3b37c;
    --shadow: 0 10px 30px -10px rgba(0,0,0,0.05);
    --transition: all 0.3s ease;
}

/* =============================================
   RESET Y ESTILOS BASE
   ============================================= */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text-primary);
    line-height: 1.6;
    min-height: 100vh;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
}

/* =============================================
   HEADER UNIFICADO
   ============================================= */
header {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0,0,0,0.03);
    position: sticky;
    top: 0;
    z-index: 100;
}

.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 70px;
}

.logo {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 8px;
}

.logo i {
    color: var(--accent);
    font-size: 1.8rem;
}

.logo span {
    color: var(--accent);
    font-weight: 300;
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
}

.nav-link {
    text-decoration: none;
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.95rem;
    padding: 8px 0;
    position: relative;
    transition: color 0.2s ease;
}

.nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: 0;
    left: 0;
    background: var(--accent);
    transition: width 0.2s ease;
}

.nav-link:hover {
    color: var(--text-primary);
}

.nav-link:hover::after {
    width: 100%;
}

.nav-link.active {
    color: var(--text-primary);
}

.nav-link.active::after {
    width: 100%;
}

/* =============================================
   CARRITO ICONO
   ============================================= */
.cart-icon {
    position: relative;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 1.2rem;
    padding: 8px;
    display: flex;
    align-items: center;
}

#cart-count {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--accent);
    color: var(--text-primary);
    font-size: 0.7rem;
    font-weight: 600;
    min-width: 18px;
    height: 18px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
}

/* =============================================
   BOTONES DE NAVEGACIÓN UNIFORMES
   ============================================= */
.btn-back, .btn-continue {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease;
    margin: 20px 0;
}

.btn-back i, .btn-continue i {
    font-size: 0.8rem;
    transition: transform 0.2s ease;
}

.btn-back:hover, .btn-continue:hover {
    color: var(--text-secondary);
}

.btn-back:hover i, .btn-continue:hover i {
    transform: translateX(-3px);
}

/* =============================================
   BOTONES PRINCIPALES
   ============================================= */
.btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 50px;
    font-weight: 500;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
}

.btn-primary {
    background: var(--accent);
    color: var(--text-primary);
}

.btn-primary:hover {
    background: var(--accent-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -8px var(--accent);
}

.btn-secondary {
    background: transparent;
    color: var(--text-primary);
    border: 1.5px solid var(--accent);
}

.btn-secondary:hover {
    background: var(--accent-light);
    border-color: var(--accent-dark);
}

.btn-block {
    width: 100%;
    justify-content: center;
}

/* =============================================
   HERO SECTION
   ============================================= */
.hero {
    padding: 6rem 0;
    min-height: 80vh;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 2;
}

.hero-content {
    max-width: 700px;
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(5px);
    padding: 3rem;
    border-radius: 50px;
    border: 1px solid rgba(255, 255, 255, 0.5);
}

.hero h1 {
    font-size: 4rem;
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 1.5rem;
}

.hero h1 span {
    color: var(--accent-dark);
    font-weight: 300;
}

/* =============================================
   FEATURES / BENEFICIOS
   ============================================= */
.features {
    padding: 5rem 0;
    background: white;
    position: relative;
    z-index: 2;
}

.section-title {
    text-align: center;
    margin-bottom: 3rem;
}

.section-title span {
    color: var(--accent-dark);
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.9rem;
    font-weight: 500;
}

.section-title h2 {
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--text-primary);
    margin-top: 0.5rem;
}

.features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
}

.feature-card {
    background: var(--card-bg);
    padding: 2.5rem;
    border-radius: 30px;
    text-align: center;
    transition: var(--transition);
    border: 1px solid rgba(248, 213, 170, 0.2);
    box-shadow: var(--shadow);
}

.feature-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 25px 40px -15px rgba(248, 213, 170, 0.4);
}

/* =============================================
   TARJETAS DE PRODUCTOS
   ============================================= */
.productos-catalogo {
    padding: 5rem 0;
    position: relative;
    z-index: 2;
}

.productos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
}

.producto-card {
    background: white;
    border-radius: 30px;
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(248, 213, 170, 0.1);
}

.producto-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.1);
}

.producto-img-container {
    position: relative;
    width: 100%;
    height: 220px;
    overflow: hidden;
    background: #f8f8f8;
}

.producto-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.producto-card:hover .producto-img {
    transform: scale(1.08);
}

.producto-info {
    padding: 1.8rem;
}

.producto-info h3 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
}

.descripcion {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 1.2rem;
    line-height: 1.5;
    height: 3rem;
    overflow: hidden;
}

.producto-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.precio {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--accent-dark);
}

.btn-add {
    background: var(--accent);
    color: var(--text-primary);
    border: none;
    padding: 8px 16px;
    border-radius: 40px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
}

.btn-add:hover {
    background: var(--accent-dark);
    transform: scale(1.05);
}

/* =============================================
   LOGIN / REGISTRO
   ============================================= */
.login-container {
    min-height: calc(100vh - 70px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: linear-gradient(145deg, #fef9f2, #fef5e9);
    position: relative;
    z-index: 2;
}

.login-card {
    background: white;
    padding: 3rem;
    border-radius: 40px;
    box-shadow: 0 30px 60px -20px rgba(248, 213, 170, 0.3);
    width: 100%;
    max-width: 450px;
    border: 1px solid rgba(248, 213, 170, 0.2);
}

.login-card h2 {
    font-size: 2rem;
    margin: 1rem 0 0.5rem;
    text-align: center;
}

.form-group {
    margin-bottom: 1.5rem;
}

.form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
    color: var(--text-primary);
}

.form-group label i {
    color: var(--accent);
    margin-right: 8px;
}

.form-group input {
    width: 100%;
    padding: 12px 16px;
    border-radius: 30px;
    border: 1.5px solid #f0e8dd;
    background: #fefaf5;
    transition: var(--transition);
    font-size: 1rem;
}

.form-group input:focus {
    border-color: var(--accent-dark);
    background: white;
    outline: none;
    box-shadow: 0 0 0 4px rgba(248, 213, 170, 0.2);
}

.login-footer {
    text-align: center;
    margin: 20px 0;
    color: var(--text-secondary);
}

.login-footer a {
    color: var(--accent-dark);
    text-decoration: none;
    font-weight: 500;
}

/* =============================================
   CARRITO DE COMPRAS
   ============================================= */
.cart-page {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 40px;
    padding: 40px 0;
    align-items: start;
}

.cart-item {
    display: grid;
    grid-template-columns: 100px 1fr 120px 40px;
    align-items: center;
    gap: 20px;
    background: white;
    padding: 20px;
    border-radius: 20px;
    margin-bottom: 15px;
    box-shadow: var(--shadow);
    border: 1px solid #f0f0f0;
}

.cart-item img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 12px;
}

.cart-item-info h4 {
    font-size: 1.1rem;
    margin-bottom: 5px;
    color: var(--text-primary);
}

.cart-item-info p {
    color: var(--accent-dark);
    font-weight: 500;
}

.quantity-controls {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #f1f5f9;
    padding: 5px 12px;
    border-radius: 30px;
}

.btn-qty {
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 1.1rem;
    cursor: pointer;
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.2s ease;
}

.btn-qty:hover {
    background: #e2e8f0;
}

.btn-remove {
    background: none;
    border: none;
    color: #cbd5e1;
    font-size: 1.2rem;
    cursor: pointer;
    transition: color 0.2s ease;
}

.btn-remove:hover {
    color: #ef4444;
}

.cart-summary {
    background: white;
    padding: 25px;
    border-radius: 20px;
    box-shadow: var(--shadow);
    border: 1px solid #f0f0f0;
    position: sticky;
    top: 90px;
}

.summary-line {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    color: var(--text-secondary);
}

.summary-line.total {
    color: var(--text-primary);
    font-weight: 600;
    font-size: 1.2rem;
    margin-top: 15px;
}

hr {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 15px 0;
}

/* =============================================
   NOTIFICACIÓN ELEGANTE
   ============================================= */
.notificacion {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: white;
    color: var(--text-primary);
    padding: 12px 24px;
    border-radius: 50px;
    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.2);
    border-left: 4px solid var(--accent);
    font-size: 0.95rem;
    z-index: 9999;
    animation: slideIn 0.3s ease;
}

@keyframes slideIn {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

/* =============================================
   FOOTER
   ============================================= */
footer {
    background: white;
    padding: 2rem 0;
    margin-top: 4rem;
    border-top: 1px solid #f0e8dd;
    text-align: center;
    color: var(--text-secondary);
}

/* =============================================
   RESPONSIVE
   ============================================= */
@media (max-width: 768px) {
    .navbar {
        flex-direction: column;
        height: auto;
        padding: 15px 0;
    }
    
    .nav-links {
        margin-top: 15px;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1.5rem;
    }
    
    .hero h1 {
        font-size: 2.5rem;
    }
    
    .cart-page {
        grid-template-columns: 1fr;
    }
    
    .cart-item {
        grid-template-columns: 80px 1fr;
        gap: 15px;
    }
    
    .quantity-controls {
        grid-column: span 2;
        justify-content: center;
    }
}